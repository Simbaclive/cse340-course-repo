<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        .project-details { padding: 20px; border: 1px solid #ccc; border-radius: 8px; }
        .category-tags { margin-top: 15px; }
        .tag { display: inline-block; background-color: #e0e0e0; padding: 5px 10px; margin-right: 5px; border-radius: 4px; text-decoration: none; color: #333; }
        .tag:hover { background-color: #d0d0d0; }
    </style>
</head>
<body>
    <div class="project-details">
        <h1><%= project.title %></h1>
        <p><%= project.description %></p>
        <p><strong>Date:</strong> <%= project.date %></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
        
      
        <div class="category-tags">
            <strong>Categories:</strong>
            <% categories.forEach(category => { %>
                <a href="/category/<%= category.category_id %>" class="tag"><%= category.category_name %></a>
            <% }); %>
        </div>

        <br>
        <a href="/projects">Back to Projects</a>
    </div>
</body>
</html>